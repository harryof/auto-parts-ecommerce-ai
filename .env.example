# ============================================================
# .env.example — шаблон для docker-compose
# Скопируй в .env и заполни своими значениями
# ============================================================

# PostgreSQL
DB_NAME=autoparts
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT (обязательно смени!)
JWT_SECRET=change_this_to_a_long_random_string

# GigaChat API credentials (base64: ClientID:ClientSecret)
GIGACHAT_CREDENTIALS=your_gigachat_credentials_base64_here
