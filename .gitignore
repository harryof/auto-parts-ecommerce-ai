# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment files (содержат секреты) ─────────────────────
.env
backend/.env
ai-agent/.env
# НЕ игнорируем .env.example — он нужен для ориентира

# ── Frontend build ────────────────────────────────────────────
frontend/dist/
frontend/.vite/

# ── Uploads (загруженные файлы) ───────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Docker ───────────────────────────────────────────────────
# (docker-compose.yml и Dockerfile коммитим)

# ── Временные файлы ──────────────────────────────────────────
tmp_*
*.log
